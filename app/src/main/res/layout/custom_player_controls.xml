<?xml version="1.0" encoding="utf-8"?>
<!-- custom_player_controls.xml - Material 3 Refinement -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="24dp"
    android:paddingBottom="24dp"
    android:background="@android:color/transparent">

    <!-- Progress Section -->
    <androidx.media3.ui.DefaultTimeBar
        android:id="@id/exo_progress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:scrubber_color="@color/spotify_green"
        app:played_color="@color/spotify_green"
        app:unplayed_color="#33FFFFFF"
        app:buffered_color="#1AFFFFFF"
        app:scrubber_enabled_size="12dp"
        app:scrubber_disabled_size="0dp" />

    <TextView
        android:id="@id/exo_position"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/spotify_light_grey"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/exo_progress" />

    <TextView
        android:id="@id/exo_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/spotify_light_grey"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/exo_progress" />

    <!-- Control Buttons -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/controller_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/exo_position">

        <ImageButton
            android:id="@id/exo_prev"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/play_pause_anchor"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/exo_ic_skip_previous"
            app:tint="@color/white" />

        <!-- Anchor point for play/pause overlapping -->
        <View
            android:id="@+id/play_pause_anchor"
            android:layout_width="1dp"
            android:layout_height="1dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@id/exo_play"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/play_pause_anchor"
            app:layout_constraintStart_toStartOf="@+id/play_pause_anchor"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/exo_ic_play_circle_filled"
            app:tint="@color/spotify_green" />

        <ImageButton
            android:id="@id/exo_pause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/play_pause_anchor"
            app:layout_constraintStart_toStartOf="@+id/play_pause_anchor"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/exo_ic_pause_circle_filled"
            app:tint="@color/spotify_green" />

        <ImageButton
            android:id="@id/exo_next"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/play_pause_anchor"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/exo_ic_skip_next"
            app:tint="@color/white" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
