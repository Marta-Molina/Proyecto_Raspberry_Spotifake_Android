<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.AppMusica" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Default flavors (Dark) -->
        <item name="colorPrimary">@color/spotify_green</item>
        <item name="colorSurface">@color/spotify_dark_grey</item>
        <item name="android:windowBackground">@color/spotify_black</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/spotify_light_grey</item>
    </style>

    <style name="Theme.AppMusica" parent="Base.Theme.AppMusica">
        <item name="android:statusBarColor">@color/spotify_black</item>
        <item name="android:navigationBarColor">@color/spotify_black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Theme Variations -->
    <style name="Theme.AppMusica.Light" parent="Theme.AppMusica">
        <item name="android:windowBackground">@color/theme_light_background</item>
        <item name="colorSurface">@color/theme_light_surface</item>
        <item name="android:textColorPrimary">@color/theme_light_text</item>
        <item name="android:textColorSecondary">#666666</item>
        <item name="android:statusBarColor">@color/theme_light_background</item>
        <item name="android:navigationBarColor">@color/theme_light_background</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.AppMusica.Premium.Gold" parent="Theme.AppMusica">
        <item name="colorPrimary">@color/premium_gold</item>
    </style>

    <style name="Theme.AppMusica.Premium.Pink" parent="Theme.AppMusica">
        <item name="colorPrimary">@color/premium_pink</item>
    </style>

    <style name="Theme.AppMusica.Premium.Blue" parent="Theme.AppMusica">
        <item name="colorPrimary">@color/premium_blue</item>
    </style>

    <style name="Theme.AppMusica.Premium.Emerald" parent="Theme.AppMusica">
        <item name="colorPrimary">@color/premium_emerald</item>
    </style>
</resources>