<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_detalle.xml -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <!-- Full Player Layout (visible when expanded) -->
    <ScrollView
        android:id="@+id/fullPlayerLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="?android:attr/windowBackground"
        android:alpha="0"
        android:visibility="invisible">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="48dp">

            <ImageButton
                android:id="@+id/btnMinimize"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_chevron_down"
                app:tint="?android:attr/textColorPrimary" />

            <!-- Vinyl Disc Container (Lowered and Enlarged to Max) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/vinylContainer"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_marginTop="32dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <!-- The Vinyl Disc -->
                <View
                    android:id="@+id/viewVinylDisc"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/vinyl_disc" />

                <!-- Circular Song Cover -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    app:cardCornerRadius="110dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/imgCancion"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        tools:src="@drawable/portada_generica" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Center Vinyl Label -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="#44FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Actual Center Hole -->
                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/spotify_black_circle"
                    android:elevation="3dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Turntable Tonearm (Patilla) - Anchored Top Right -->
            <ImageView
                android:id="@+id/imgTonearm"
                android:layout_width="60dp"
                android:layout_height="200dp"
                android:src="@drawable/ic_tonearm_minimal"
                android:elevation="10dp"
                android:transformPivotX="30dp"
                android:transformPivotY="30dp"
                android:rotation="0"
                app:layout_constraintTop_toTopOf="@id/vinylContainer"
                app:layout_constraintStart_toEndOf="@id/vinylContainer"
                android:layout_marginTop="-10dp"
                android:layout_marginStart="-30dp" />

            <TextView
                android:id="@+id/txtNombre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="16dp"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@+id/btnLike"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/vinylContainer"
                tools:text="Song title" />

            <ImageButton
                android:id="@+id/btnLike"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintBottom_toBottomOf="@+id/txtNombre"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/txtNombre"
                app:srcCompat="@android:drawable/btn_star_big_off"
                app:tint="?android:attr/textColorPrimary" />

            <TextView
                android:id="@+id/txtLikesCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="10sp"
                app:layout_constraintEnd_toEndOf="@+id/btnLike"
                app:layout_constraintStart_toStartOf="@+id/btnLike"
                app:layout_constraintTop_toBottomOf="@+id/btnLike"
                tools:text="125 likes" />

            <TextView
                android:id="@+id/txtArtista"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txtNombre"
                tools:text="Marina" />

            <TextView
                android:id="@+id/txtAlbum"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp"
                android:alpha="0.8"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txtArtista"
                tools:text="Froot (Album)" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:valueFrom="0"
                android:valueTo="100"
                app:thumbColor="@color/spotify_green"
                app:trackColorActive="@color/spotify_green"
                app:trackColorInactive="?android:attr/textColorSecondary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txtAlbum" />

            <TextView
                android:id="@+id/txtCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="10sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/sliderProgress" />

            <TextView
                android:id="@+id/txtTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="10sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/sliderProgress" />

            <LinearLayout
                android:id="@+id/controlsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/txtCurrentTime">

                <ImageButton
                    android:id="@+id/btnRepeat"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="16dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:srcCompat="@drawable/ic_repeat"
                    app:tint="?android:attr/textColorPrimary" />

                <ImageButton
                    android:id="@+id/btnPrev"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="16dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:srcCompat="@drawable/exo_ic_skip_previous"
                    app:tint="?android:attr/textColorPrimary" />

                <ImageButton
                    android:id="@+id/btnPlayPause"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@android:color/transparent"
                    android:scaleType="fitCenter"
                    app:srcCompat="@drawable/exo_ic_play_circle_filled"
                    app:tint="@color/spotify_green" />

                <ImageButton
                    android:id="@+id/btnNext"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginStart="16dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:srcCompat="@drawable/exo_ic_skip_next"
                    app:tint="?android:attr/textColorPrimary" />
            </LinearLayout>

            <!-- Invisible PlayerView to avoid ExoPlayer issues if needed -->
            <androidx.media3.ui.PlayerView
                android:id="@+id/playerView"
                android:layout_width="1dp"
                android:layout_height="1dp"
                app:use_controller="false"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                tools:ignore="MissingClass" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Mini Player Layout (visible when peeked) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/miniPlayerLayout"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="?android:attr/windowBackground"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgMiniCancion"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/portada_generica" />

        <TextView
            android:id="@+id/txtMiniNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?android:attr/textColorPrimary"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/txtMiniArtista"
            app:layout_constraintEnd_toStartOf="@+id/btnMiniPrev"
            app:layout_constraintStart_toEndOf="@id/imgMiniCancion"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="Song Title" />

        <TextView
            android:id="@+id/txtMiniArtista"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/spotify_light_grey"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/txtMiniNombre"
            app:layout_constraintStart_toStartOf="@id/txtMiniNombre"
            app:layout_constraintTop_toBottomOf="@id/txtMiniNombre"
            tools:text="Artist" />

        <ImageButton
            android:id="@+id/btnMiniPrev"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnMiniPlayPause"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/exo_ic_skip_previous"
            app:tint="?android:attr/textColorPrimary" />

        <ImageButton
            android:id="@+id/btnMiniPlayPause"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnMiniNext"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/exo_ic_play_circle_filled"
            app:tint="@color/spotify_green" />

        <ImageButton
            android:id="@+id/btnMiniNext"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/exo_ic_skip_next"
            app:tint="@color/white" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
